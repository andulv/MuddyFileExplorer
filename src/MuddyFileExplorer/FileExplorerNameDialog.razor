@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudTextField T="string"
                      @ref="_nameInput"
                      @bind-Value="_value"
                      Label="@Label"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Required="true"
                      OnKeyDown="HandleKeyDown" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@string.IsNullOrWhiteSpace(_value)" OnClick="Submit">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudTextField<string>? _nameInput;
    private string _value = string.Empty;
    private bool _selectAllPending;

    [CascadingParameter]
    public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Label { get; set; } = "Name";

    [Parameter]
    public string Value { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        _value = Value;
        _selectAllPending = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_selectAllPending || _nameInput is null)
        {
            return;
        }

        _selectAllPending = false;
        await _nameInput.FocusAsync();
        await Task.Delay(50);
        await _nameInput.SelectRangeAsync(0, _value.Length);
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !string.IsNullOrWhiteSpace(_value))
        {
            Submit();
        }
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(_value.Trim()));

    private void Cancel() => MudDialog.Cancel();
}
