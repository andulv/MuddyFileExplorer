@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudTextField T="string"
                      @bind-Value="_value"
                      Label="@Label"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      AutoFocus="true"
                      Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@string.IsNullOrWhiteSpace(_value)" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private string _value = string.Empty;

    [CascadingParameter]
    public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Label { get; set; } = "Name";

    [Parameter]
    public string Value { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        _value = Value;
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(_value.Trim()));

    private void Cancel() => MudDialog.Cancel();
}
