@namespace MuddyFileExplorer.Components

<div class="muddy-file-explorer-shell d-flex flex-1">
    <MudPaper Class="muddy-file-explorer d-flex flex-column flex-1" Elevation="0" Outlined="true">
        <MudToolBar Dense="@Dense" Class="flex-none gap-1 ps-4 pe-2 muddy-file-explorer-toolbar">
            @if (AllowUpload)
            {
                <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                               Accept="@AcceptedFileTypes"
                               MaxFileSize="@MaxUploadFileSize"
                               MaximumFileCount="@MaximumUploadCount"
                               AppendMultipleFiles="true"
                               DragAndDrop="true"
                               Hidden="true"
                               FilesChanged="QueueUploadsAsync">
                    <CustomContent Context="upload">
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" aria-label="Upload"
                                   OnClick="upload.OpenFilePickerAsync" Disabled="@_busy"
                                   StartIcon="@Icons.Material.Filled.CloudUpload" Color="Color.Info">Upload
                        </MudButton>
                    </CustomContent>
                    <SelectedTemplate />
                </MudFileUpload>
            }

            @if (AllowCreateFolder)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="CreateFolderAsync" Disabled="@_busy"
                           StartIcon="@Icons.Material.Filled.CreateNewFolder" Color="Color.Primary">New folder
                </MudButton>
            }

            <MudSpacer />

            <MudTextField T="string"
                          @bind-Value="_searchText"
                          Placeholder="Search"
                          Margin="Margin.Dense"
                          Variant="Variant.Text"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Clearable="true"
                          Class="muddy-file-explorer-search" />
        </MudToolBar>

        <MudDivider Class="flex-none" />

        <div class="flex-none d-flex flex-direction-row">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0" Class="flex-1 px-2">
                @foreach (var folder in _listing?.Breadcrumbs ?? [])
                {
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@(folder.ParentId is null ? Icons.Material.Filled.Home : null)"
                               OnClick="@(() => NavigateToFolderAsync(folder.Id))">
                        @folder.Name
                    </MudButton>
                    @if (!ReferenceEquals(folder, (_listing?.Breadcrumbs ?? []).Last()))
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" />
                    }
                }
                @if (_busy)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
            </MudStack>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" aria-label="Refresh"
                           Size="Size.Small" Color="Color.Default" Class="flex-none"
                           OnClick="RefreshAsync" Disabled="@_busy" />
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="ma-2">@_error</MudAlert>
        }

        <MudDataGrid T="FileExplorerItem"
                     Items="@FilteredItems"
                     Dense="@Dense"
                     Hover="true"
                     Striped="true"
                     FixedHeader="true"
                     Height="100%"
                     MultiSelection="@MultiSelection"
                     SelectOnRowClick="false"
                     SelectedItems="@_selectedItems"
                     SelectedItemsChanged="SelectionChangedAsync"
                     RowClick="RowClickedAsync"
                     RowClassFunc="RowClassFunc"
                     Bordered="false"
                     Elevation="0"
                     Class="flex-1 d-flex muddy-file-explorer-grid">
            <ColGroup>
                @if (MultiSelection)
                {
                    <col style="width:36px;" />
                }
                <col style="width:36px;" />
                <col />
                <col style="width:80px;" />
                <col style="width:80px;" />
                <col style="width:140px;" />
                <col style="width:48px;" />
            </ColGroup>
            <Columns>
                @if (MultiSelection)
                {
                    <SelectColumn T="FileExplorerItem" />
                }
                <TemplateColumn Title="" Sortable="false" Filterable="false">
                    <CellTemplate Context="cell">
                        <MudIcon Icon="@GetIcon(cell.Item)" Size="Size.Small" Color="@GetIconColor(cell.Item)" />
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Name" SortBy="item => item.Name" Sortable="true"
                                CellStyle="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:0;">
                    <CellTemplate Context="cell">
                        <span title="@cell.Item.Name">@cell.Item.Name</span>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Size" SortBy="item => item.Size ?? -1" Sortable="true" CellStyle="white-space:nowrap;">
                    <CellTemplate Context="cell">
                        <MudText Typo="Typo.body2">@FormatSize(cell.Item)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="item => item.Type" Title="Type" CellStyle="white-space:nowrap;" />
                <TemplateColumn Title="Date" SortBy="item => item.ModifiedAt" Sortable="true" CellStyle="white-space:nowrap;">
                    <CellTemplate Context="cell">
                        <MudText Typo="Typo.body2">@cell.Item.ModifiedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="" Sortable="false" Filterable="false" CellStyle="white-space:nowrap;padding-right:8px;">
                    <CellTemplate Context="cell">
                        <MudMenu Dense="@Dense" Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            @RowMenu(cell.Item)
                        </MudMenu>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="pa-4">No files found</MudText>
            </NoRecordsContent>
        </MudDataGrid>

        @if (_uploads.Count > 0)
        {
            <MudDivider Class="flex-none" />
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-none py-1 px-2">
                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Color="@GetConsolidatedUploadColor()" />
                <MudProgressLinear Value="@ConsolidatedUploadPercent" Color="@GetConsolidatedUploadColor()" Class="flex-1 muddy-file-explorer-upload-progress" />
                <MudText Typo="Typo.caption" Class="flex-1 muddy-file-explorer-upload-name">@GetConsolidatedUploadText()</MudText>
                @if (AllUploadsComplete)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="DismissUploadsAsync" aria-label="Dismiss" />
                }
            </MudStack>
        }

        <MudDivider Class="flex-none" />

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-none px-2">
            <MudText Typo="Typo.caption">@StatusText</MudText>
            <MudSpacer />
            <MudText Typo="Typo.caption">@_operationText</MudText>
        </MudStack>
    </MudPaper>
</div>
